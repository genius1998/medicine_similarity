{
  "api_service_name": "seongbunkok",
  "api_default_top_k": 10,
  "api_default_candidate_limit": 1000,
  "api_default_max_df_for_seed": 3000,
  "api": {
    "debug_response": false
  },
  "auth": {
    "default_admin_email": "admin@example.com",
    "default_admin_password": "",
    "session_cookie_name": "sb_session",
    "session_hours": 12,
    "cookie_secure": false
  },
  "google_ocr": {
    "enabled": true,
    "credentials_path": "google_ocr_key"
  },
  "local_llm": {
    "enabled": true,
    "base_url": "http://127.0.0.1:3000/api/chat",
    "timeout_sec": 120,
    "max_retries": 2
  },
  "ingredient_match_llm": {
    "provider": "openai",
    "model": "gpt-5-nano",
    "api_key_env": "OPENAI_API_KEY",
    "env_path": "",
    "base_url": "https://api.openai.com/v1/responses",
    "timeout_sec": 20,
    "max_retries": 1,
    "max_output_tokens": 700,
    "reasoning_effort": "minimal",
    "fallback_to_local": false
  },
  "ingredient_embedding": {
    "enabled": true,
    "model_name": "sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2",
    "metadata_path": "output/ingredient_match_v2_promoted/functional_ingredient_metadata_v2_promoted.pkl",
    "documents_path": "output/ingredient_match_v2_promoted/new_standard_candidate_rag_documents_promoted.csv",
    "synonym_path": "",
    "cache_path": "tmp/ingredient_embedding_cache"
  },
  "upload": {
    "temp_dir": "tmp/uploads",
    "max_file_size_mb": 10,
    "allowed_extensions": [".jpg", ".jpeg", ".png", ".webp"]
  }
}
